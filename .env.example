# Required
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# How often to refresh the ranked model list (seconds)
MODEL_REFRESH_SECONDS=300

# How often to refresh the LMSYS ELO leaderboard (seconds)
LEADERBOARD_REFRESH_SECONDS=3600

# Number of free models to try before giving up (or falling back to paid)
MAX_FALLBACK_ATTEMPTS=3

# Optional paid model as final fallback (leave empty to disable)
# Example: anthropic/claude-3-5-sonnet
PAID_FALLBACK_MODEL=

# Comma-separated model IDs to skip entirely
# Example: mistralai/mistral-7b-instruct,nousresearch/nous-capybara-7b
MODEL_BLOCKLIST=

# Restrict to specific providers only (comma-separated). Leave empty = all providers.
# Example: meta-llama,mistralai
ALLOW_PROVIDERS=

# Set to false to disable LMSYS ELO leaderboard integration
USE_LEADERBOARD=true

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Minimum parameter count (billions) to consider a model general-purpose.
# Models smaller than this are excluded. Default: 7
MIN_PARAMS_BILLIONS=7
